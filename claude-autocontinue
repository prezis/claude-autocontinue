#!/usr/bin/env bash
#
# claude-autocontinue — zero-dependency tmux monitor that types `continue`
# into Claude Code sessions when their rate-limit resets.
#
# Philosophy: one bash file, no daemons, no config files. Runs in any tmux
# pane, polls all panes across all sessions, acts only on panes showing the
# actual Claude Code rate-limit banner.
#
# Project:  https://github.com/prezis/claude-autocontinue
# License:  MIT
#
set -euo pipefail

VERSION="1.2.0"

# ── Defaults (override with CLI flags) ────────────────────────────────────────
POLL_INTERVAL=300         # Seconds between full sweeps. Rate limits last 10-60m.
SEND_COOLDOWN=60          # Min seconds between 'continue' sends to the same pane (usage limit).
SERVER_LIMIT_COOLDOWN=120 # Min seconds between retries on transient server rate-limit errors.
SCROLLBACK_DEPTH=200      # Lines of tmux capture-pane scrollback to scan.
TAIL_LINES=30             # Only inspect the last N lines for the live banner.
MAX_WAIT_SECONDS=172800   # Cap "sleep until reset" at 48h (dated banners can be 24h+ away).
LOG_FILE=""               # Empty = stdout only; otherwise tee to this path.
DRY_RUN=0                 # 1 = detect + log, never send keys.
VERBOSE=0                 # 1 = log every pane decision, not just actions.

# Per-pane cooldown tracking: LAST_SEND["%4"]=<epoch-of-last-send>
declare -gA LAST_SEND
declare -gA LAST_SERVER_SEND

# ── Portability shims: BSD `date` on macOS lacks `-d`, GNU has it ──────────────
DATE_BIN="date"
if ! date -d "2pm" +%s >/dev/null 2>&1; then
    if command -v gdate >/dev/null 2>&1; then
        DATE_BIN="gdate"
    else
        echo "error: need GNU date with -d support (install coreutils: 'brew install coreutils' on macOS)" >&2
        exit 1
    fi
fi

# ── Logging ───────────────────────────────────────────────────────────────────
log() {
    local ts msg
    ts="$($DATE_BIN +%H:%M:%S)"
    msg="[$ts] $*"
    if [ -n "$LOG_FILE" ]; then
        printf '%s\n' "$msg" | tee -a "$LOG_FILE"
    else
        printf '%s\n' "$msg"
    fi
}

log_verbose() {
    if [ "$VERBOSE" = 1 ]; then
        log "$@"
    fi
}

# ── Pure functions (testable) ─────────────────────────────────────────────────

# is_claude_code <content>
# Returns 0 if the content looks like a live Claude Code TUI pane.
# Detects by persistent UI markers rather than window name (which users rename).
is_claude_code() {
    local content="$1"
    printf '%s' "$content" | grep -qE '⏵⏵|esc to interrupt|shift\+tab to cycle'
}

# has_rate_limit_banner <tail_content>
# Tight regex: requires the possessive "You've" contraction (rare in prose)
# OR the "Limit reached" phrase followed by whitespace + a banner glyph
# (· middle-dot, ∙ bullet, or open paren for the minutes-remaining format).
# Scope to the TAIL of the capture since Claude Code always redraws its status
# at the bottom of the TUI — full scrollback may contain prose/logs that
# mention the banner text without being the live banner.
has_rate_limit_banner() {
    local tail_content="$1"
    printf '%s' "$tail_content" \
        | grep -qE "[Yy]ou[']ve hit your limit|[Ll]imit reached[[:space:]]+[·∙(]"
}

# has_server_rate_limit_error <tail_content>
# Detects the *transient* server-side rate limit (HTTP 429/529 from the
# Anthropic API), distinct from the personal usage limit. Format Claude Code
# prints inline:
#   API Error: Server is temporarily limiting requests (not your usage limit) · Rate limited
# Has NO reset time — the server is overloaded and clears on its own in seconds
# to minutes. Strategy: send `continue` to retry, then enforce a longer cooldown
# (SERVER_LIMIT_COOLDOWN) so we don't hammer an already-overloaded backend.
# Same tail-only scoping rationale as has_rate_limit_banner.
# Regex allows an optional HTTP status code between "API Error:" and the phrase
# (Claude Code may render either "API Error: Server..." or "API Error: 429 Server...").
has_server_rate_limit_error() {
    local tail_content="$1"
    printf '%s' "$tail_content" \
        | grep -qE "API Error:[[:space:]]+([0-9]+[[:space:]]+)?Server is temporarily limiting requests"
}

# parse_reset_time <tail_content>
# Extract the last reset time string like "Apr 23, 9pm", "2am", "10:30pm".
# Returns empty string if none found. Uses grep -oE (portable) + sed to drop
# the `resets ` prefix; avoids `grep -P \K` which isn't on BSD grep.
#
# v1.2.0: Claude Code changed the banner from `resets 2am (Europe/London)` to
# `resets Apr 23, 9pm (Europe/London)` — the date prefix broke the old regex
# and `parse_reset_time` returned empty, which in v1.1.0 silently triggered
# the "unparseable → send continue immediately" fallback branch, producing a
# 60s spam loop for the entire limit window. Fix: match the dated form first,
# keep the legacy form as fallback. Tail is trimmed so the TZ suffix is
# handled separately by epoch_of_reset.
parse_reset_time() {
    local tail_content="$1" dated legacy
    # New format: "resets Apr 23, 9pm" (optionally followed by " (Area/City)")
    # Capture up to the am/pm marker — TZ suffix is parsed out of the extracted
    # token inside epoch_of_reset, not here (keeps the regex readable).
    dated="$(printf '%s' "$tail_content" \
        | { grep -oiE 'resets?[[:space:]]+[A-Z][a-z]+[[:space:]]+[0-9]{1,2},?[[:space:]]*[0-9]{1,2}(:[0-9]{2})?[[:space:]]*[ap]m' || true; } \
        | tail -1 \
        | sed -E 's/^[Rr]esets?[[:space:]]+//')"
    if [ -n "$dated" ]; then
        printf '%s' "$dated"
        return
    fi
    # Legacy format: "resets 2am" / "resets 10:30pm"
    printf '%s' "$tail_content" \
        | { grep -oiE 'resets?[[:space:]]+[0-9]{1,2}(:[0-9]{2})?[[:space:]]*[ap]m' || true; } \
        | tail -1 \
        | sed -E 's/^[Rr]esets?[[:space:]]+//'
}

# parse_reset_timezone <tail_content>
# Extract the last "(Area/City)" timezone marker that follows a reset banner.
# Returns empty string if none. We deliberately only match within a short
# window after `resets …[ap]m` so that an unrelated "(Europe/London)" earlier
# in scrollback (e.g. a pasted log line) doesn't win — the banner is always
# the LAST match so we grep the whole tail for "resets … am/pm (TZ)" and
# strip everything except the TZ.
parse_reset_timezone() {
    local tail_content="$1" matched
    matched="$(printf '%s' "$tail_content" \
        | { grep -oiE 'resets?[[:space:]]+[^)]*[ap]m[[:space:]]*\([A-Za-z_]+/[A-Za-z_]+\)' || true; } \
        | tail -1)"
    [ -z "$matched" ] && return 0
    printf '%s' "$matched" \
        | grep -oE '\([A-Za-z_]+/[A-Za-z_]+\)' \
        | tr -d '()'
}

# epoch_of_reset <reset_time_string> [timezone]
# Parse "Apr 23, 9pm" / "2am" / "10:30pm" into a unix epoch. Echoes 0 on
# failure. Uses $DATE_BIN so macOS (gdate) works. Strips the comma in the
# dated form since GNU date -d accepts "Apr 23 9pm" but rejects "Apr 23, 9pm".
# If an IANA timezone is provided, interprets the reset string in that zone —
# this matters because Claude Code's banner always specifies its TZ
# (e.g. Europe/London) and users may be running claude-autocontinue in a
# different system TZ (servers, containers, laptops on trips).
epoch_of_reset() {
    local reset="$1" tz="${2:-}" clean
    [ -z "$reset" ] && { echo 0; return; }
    # Drop the comma between day-of-month and hour.
    clean="$(printf '%s' "$reset" | sed -E 's/,//g')"
    if [ -n "$tz" ]; then
        TZ="$tz" $DATE_BIN -d "$clean" +%s 2>/dev/null || echo 0
    else
        $DATE_BIN -d "$clean" +%s 2>/dev/null || echo 0
    fi
}

# ── Tmux wrappers ─────────────────────────────────────────────────────────────

pane_exists() {
    tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qx "$1"
}

capture_pane() {
    tmux capture-pane -t "$1" -p -S "-${SCROLLBACK_DEPTH}" 2>/dev/null || true
}

send_continue() {
    local pane_id="$1" window_name="$2"
    if [ "$DRY_RUN" = 1 ]; then
        log "DRY-RUN $window_name ($pane_id): would send 'continue'"
        return
    fi
    if ! pane_exists "$pane_id"; then
        log "$window_name ($pane_id): pane gone, skipping"
        return
    fi
    log "$window_name ($pane_id): sending continue"
    tmux send-keys -t "$pane_id" "continue" Enter
    LAST_SEND["$pane_id"]="$($DATE_BIN +%s)"
}

# ── Main polling loop ─────────────────────────────────────────────────────────

poll_once() {
    local panes pane_id window_name content tail_content reset reset_tz now reset_epoch last wait remaining last_server

    # Use `|` as field separator so window names with spaces don't split.
    panes="$(tmux list-panes -a -F '#{pane_id}|#{window_name}' 2>/dev/null || true)"
    [ -z "$panes" ] && return

    while IFS='|' read -r pane_id window_name; do
        [ -z "$pane_id" ] && continue

        content="$(capture_pane "$pane_id")"
        is_claude_code "$content" || { log_verbose "$window_name ($pane_id): not claude code"; continue; }

        tail_content="$(printf '%s\n' "$content" | tail -n "$TAIL_LINES")"
        now="$($DATE_BIN +%s)"

        # ── Branch A: transient server rate-limit (no reset time, retry now) ──
        # Checked before the usage-limit branch because both can in theory
        # appear in the same tail; a server error in the tail is the more
        # recent state and warrants an immediate retry rather than a long sleep.
        if has_server_rate_limit_error "$tail_content"; then
            last_server="${LAST_SERVER_SEND[$pane_id]:-0}"
            if [ "$((now - last_server))" -lt "$SERVER_LIMIT_COOLDOWN" ]; then
                log_verbose "$window_name ($pane_id): server rate-limit, in cooldown ($((now - last_server))s < ${SERVER_LIMIT_COOLDOWN}s)"
                continue
            fi
            log "$window_name ($pane_id): server rate-limit (transient) — sending continue"
            send_continue "$pane_id" "$window_name"
            LAST_SERVER_SEND["$pane_id"]="$($DATE_BIN +%s)"
            sleep 2
            continue
        fi

        # ── Branch B: personal usage limit (parse reset time, sleep until) ──
        has_rate_limit_banner "$tail_content" || { log_verbose "$window_name ($pane_id): claude, no banner"; continue; }

        # Per-pane cooldown prevents spam from surviving banners in scrollback.
        last="${LAST_SEND[$pane_id]:-0}"
        if [ "$((now - last))" -lt "$SEND_COOLDOWN" ]; then
            log_verbose "$window_name ($pane_id): banner seen, in cooldown ($((now - last))s < ${SEND_COOLDOWN}s)"
            continue
        fi

        reset="$(parse_reset_time "$tail_content")"
        if [ -z "$reset" ]; then
            # v1.2.0 safety fix: previous behaviour was send_continue here,
            # which spam-looped when banner format changed (e.g. the Apr 2026
            # `resets Apr 23, 9pm (Europe/London)` form the v1.1 regex missed).
            # Sending `continue` while the limit is active does nothing useful
            # — it just re-prints the same banner. Back off instead and let
            # the outer POLL_INTERVAL retry; by then the banner may have
            # cleared OR a format we recognise may be in view.
            log "$window_name ($pane_id): banner detected, no reset time parsed — backing off (not sending)"
            LAST_SEND["$pane_id"]="$now"
            continue
        fi

        reset_tz="$(parse_reset_timezone "$tail_content")"
        reset_epoch="$(epoch_of_reset "$reset" "$reset_tz")"
        if [ "$reset_epoch" = 0 ]; then
            # Same safety fix as above: unparseable reset ≠ send continue.
            log "$window_name ($pane_id): banner detected, reset '$reset' unparseable — backing off (not sending)"
            LAST_SEND["$pane_id"]="$now"
            continue
        fi

        if [ "$now" -ge "$reset_epoch" ]; then
            log "$window_name ($pane_id): reset time ($reset) passed — sending continue"
            send_continue "$pane_id" "$window_name"
            sleep 2
            continue
        fi

        remaining=$(( (reset_epoch - now) / 60 ))
        wait=$(( reset_epoch - now + 30 ))
        log "$window_name ($pane_id): rate-limited, resets in ${remaining}m ($reset${reset_tz:+ $reset_tz})"
        if [ "$wait" -gt 0 ] && [ "$wait" -lt "$MAX_WAIT_SECONDS" ]; then
            log "  sleeping ${wait}s until reset"
            sleep "$wait"
            return  # break out of this poll pass so the next one re-scans everything fresh
        fi
        if [ "$wait" -ge "$MAX_WAIT_SECONDS" ]; then
            # Reset is further away than our sleep cap. Do NOT send continue —
            # the banner is active and any send just echoes it back. Mark the
            # per-pane cooldown and let POLL_INTERVAL re-check later.
            log "  reset is ${wait}s away (> MAX_WAIT_SECONDS=${MAX_WAIT_SECONDS}s); skipping without sending"
            LAST_SEND["$pane_id"]="$now"
            continue
        fi
    done <<< "$panes"
}

# ── Signal handling ───────────────────────────────────────────────────────────

on_exit() {
    log "claude-autocontinue stopping"
    exit 0
}
trap on_exit INT TERM

# ── CLI ───────────────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
claude-autocontinue — auto-resume Claude Code tmux panes after rate limits

Usage:
  claude-autocontinue [OPTIONS]

Options:
  --interval N         Seconds between poll sweeps      (default: 300)
  --cooldown N         Min seconds between 'continue' sends per pane (default: 60)
  --server-cooldown N  Min seconds between retries on transient server rate limits (default: 120)
  --scrollback N       Tmux capture scrollback depth     (default: 200)
  --tail N             Lines at end of capture to scan   (default: 30)
  --max-wait N         Cap for "sleep until reset" (sec) (default: 172800 = 48h)
  --log-file PATH      Tee log output to this file
  --dry-run            Detect and log only — never send keys
  --verbose            Log per-pane decisions, not just actions
  -h, --help           Show this help
  -V, --version        Print version and exit

Run it in any tmux pane:
  claude-autocontinue &

It discovers Claude Code sessions automatically across all tmux sessions by
content signature (not window name), so `/rename` inside Claude Code does not
break detection.
EOF
}

# Library mode: when sourced (e.g. from tests) with CAC_LIB_ONLY=1, expose
# the pure functions without starting the daemon, running preflight, or
# consuming the positional args (which bats may set to the current test
# name; that would otherwise blow up our CLI parser).
# `return` only works when sourced; if someone happened to execute the script
# with this variable set, fall back to `exit 0`. shellcheck SC2317 sees the
# `exit` as unreachable because it only analyses one entry mode.
if [ "${CAC_LIB_ONLY:-0}" = 1 ]; then
    return 0 2>/dev/null
    # shellcheck disable=SC2317
    exit 0
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --interval)         POLL_INTERVAL="$2"; shift 2 ;;
        --cooldown)         SEND_COOLDOWN="$2"; shift 2 ;;
        --server-cooldown)  SERVER_LIMIT_COOLDOWN="$2"; shift 2 ;;
        --scrollback)       SCROLLBACK_DEPTH="$2"; shift 2 ;;
        --tail)             TAIL_LINES="$2"; shift 2 ;;
        --max-wait)         MAX_WAIT_SECONDS="$2"; shift 2 ;;
        --log-file)         LOG_FILE="$2"; shift 2 ;;
        --dry-run)          DRY_RUN=1; shift ;;
        --verbose|-v)       VERBOSE=1; shift ;;
        -h|--help)          usage; exit 0 ;;
        -V|--version)       echo "claude-autocontinue $VERSION"; exit 0 ;;
        *) echo "unknown option: $1" >&2; usage >&2; exit 2 ;;
    esac
done

# Preflight: confirm tmux is available and a server is running.
command -v tmux >/dev/null 2>&1 || { echo "error: tmux not found in PATH" >&2; exit 1; }
tmux list-sessions >/dev/null 2>&1 || { echo "error: no running tmux server" >&2; exit 1; }

log "claude-autocontinue $VERSION starting"
log "poll=${POLL_INTERVAL}s cooldown=${SEND_COOLDOWN}s server-cooldown=${SERVER_LIMIT_COOLDOWN}s scrollback=${SCROLLBACK_DEPTH} tail=${TAIL_LINES}${DRY_RUN:+ DRY-RUN}"

while true; do
    poll_once
    sleep "$POLL_INTERVAL"
done
